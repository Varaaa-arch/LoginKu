<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark_navy"
    android:padding="24dp">

    <TextView
        android:id="@+id/tvLogoutMessage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:background="@drawable/bg_badge"
        android:padding="12dp"
        android:text="Terimakasih Bizar Givardi atas kunjungan Anda."
        android:textColor="@color/neon_blue"
        android:textStyle="bold"
        android:visibility="gone"
        android:gravity="center"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_top_toTopOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="LoginKu"
            android:textSize="40sp"
            android:fontFamily="sans-serif-black"
            android:textColor="@color/neon_blue" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Silakan masuk untuk melanjutkan"
            android:textColor="@color/text_gray"
            android:textSize="16sp"
            android:layout_marginBottom="40dp" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:textColorHint="@color/text_gray"
            app:hintTextColor="@color/neon_blue"
            app:boxStrokeColor="@color/neon_blue"
            app:boxBackgroundColor="@color/input_bg"
            style="@style/Widget.MaterialComponents.TextInputLayout.FilledBox">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etUsername"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Username"
                android:textColor="@color/white" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:textColorHint="@color/text_gray"
            app:hintTextColor="@color/neon_blue"
            app:boxStrokeColor="@color/neon_blue"
            app:boxBackgroundColor="@color/input_bg"
            app:passwordToggleEnabled="true"
            app:passwordToggleTint="@color/text_gray"
            style="@style/Widget.MaterialComponents.TextInputLayout.FilledBox">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etPassword"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Password"
                android:inputType="textPassword"
                android:textColor="@color/white" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:id="@+id/tvError"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/error_red_bg"
            android:padding="12dp"
            android:text="Username atau Password salah!"
            android:textColor="@color/error_red_text"
            android:layout_marginBottom="16dp"
            android:gravity="center"
            android:visibility="gone"/>

        <Button
            android:id="@+id/btnLogin"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="MASUK KE DASHBOARD"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:backgroundTint="@color/neon_blue"
            app:cornerRadius="16dp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>